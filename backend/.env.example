# MongoDB (Atlas ou local)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/personal-org?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Server
PORT=3001
NODE_ENV=development

# CORS (frontend URL)
CORS_ORIGIN=http://localhost:5173

# OpenRouter (opcional — para assistente IA)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=gpt-4o-mini
